      "regex": "^/api/media/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/media/(?<nxtPid>[^/]+?)(?:/)?$"
    },
