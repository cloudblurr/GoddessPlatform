{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/mock-media/layout,_N_T_/mock-media/page,_N_T_/mock-media"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/mock-media/__PAGE__",
    "/mock-media",
    "/_index",
    "/_head"
  ]
}